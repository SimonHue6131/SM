@* @inject DB db *@
@model List<User>

@foreach (var user in Model)
{
    <a href="/Account/Profile/@@@(user?.Username)/@(user?.Id)">
        <span style="display:flex; font-size: 27px; font-weight:bolder; padding:20px">
            <img src="~/images/profile/@(user?.PhotoURL)" style="width: 65px; margin-right:20px; border-radius:50%">
            @(user?.Username)
        </span>
    </a>
}

@if(Model.Count == 0)
{
    <p>No users :(</p>
}

