<div id="profile_nv_post">
    <form id="profile_form" data-ajax="true" data-ajax-method="get" data-ajax-loading="#loader" data-ajax-update="#profile_content">
            <input type="radio" class="profile_sub_radio1" name="profile_sub_menu" value="show_all" id="show_all" checked>
            <label for="show_all" class="profile_sub_label">All</label>

            <input type="radio" class="profile_sub_radio2" name="profile_sub_menu" value="show_text" id="show_text">
            <label for="show_text" class="profile_sub_label">Text</label>

            <input type="radio" class="profile_sub_radio3" name="profile_sub_menu" value="show_media" id="show_media">
            <label for="show_media" class="profile_sub_label">Media</label>


            <div id="profile_sub_bar"></div>
    </form>

    <form data-ajax="true" data-ajax-method="get" data-ajax-loading="#loader" data-ajax-update="#profile_content" asp-controller="Post" asp-action="Profile_LoadSearchedPost"
          style="display:flex;">
        <input type="text" id="profile_searchbox" placeholder="Search something!" name=searchbox>
        <input type="submit" id="profile_searchbutton" value="">

        <input type="hidden" name="profileId" value="@Model.Id" />
    </form>
</div>

<div id="profile_content">
    <div style="text-align:center; font-size: 20px" id="loader">
        <img id="profile-loader" src="~/images/icon/lacie_spin.gif" style="height:240px" />
        <p>Loading...</p>
    </div>
    @if (!posts.Any(p => p.Anomymous == 0))
    {
        <div style="text-align:center; font-size: 20px">
            <img src="~/images/icon/lacie_sigh.png" style="height:260px" />
            <p>User didn't post any contents</p>
        </div>
    }

    @foreach (var post in posts)
    {
        @if (post.Anomymous == 0 || User.IsInRole("1"))
        {
            <div class="center-post" id="postbox-@post.Id">
                @Html.Partial("../Post/_LoadPost", post)
            </div>
        }
    }


    @* <div style="text-align:center; font-size: 20px">
    <img src="~/images/icon/lacie_sigh.png" style="height:260px"/>
    <p>User didn't post any contents</p>
    </div> *@
</div>

<script>
    document.querySelectorAll('input[name="profile_sub_menu"]').forEach(radio => {
    radio.addEventListener('change', function () {
        const form = document.getElementById('profile_form');
        switch (this.value) {
            case "show_all":
                form.action = "/Post/Profile_LoadAllPost?ProfileId=@Model.Id";
                break;
            case "show_text":
                console.log("load text");
                form.action = "/Post/Profile_LoadTextPost?ProfileId=@Model.Id";
                break;
            case "show_media":
                console.log("load media");
                form.action = "/Post/Profile_LoadMediaPost?ProfileId=@Model.Id";
                break;
            default:
                form.action = "/Post/Profile_LoadAllPost?ProfileId=@Model.Id";
                break;
        }
        $(form).submit();
    });
});
</script>