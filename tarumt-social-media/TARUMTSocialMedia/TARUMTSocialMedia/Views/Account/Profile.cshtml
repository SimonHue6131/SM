@inject DB db
@await Html.PartialAsync("_blackout");

@model User
@{
    var u = db.Users.FirstOrDefault(x => x.Email == User.Identity!.Name);
    var posts = db.Post.Where(p => p.User.Id == Model.Id).OrderByDescending(p => p.Id).ToList();
    bool followed = db.Follows.Any(x => x.UserId == u!.Id && x.FollowedUserId == Model.Id);
}
<div id="profile_menu">
    <div id="profile_banner" style="background-image: url('/images/banner/@(Model.Detail?.BannerURL)')">
    </div>

    <div id="profile_image_container">
        <img id="profile_image" src=~/images/profile/@(Model.PhotoURL)>
    </div>
    
    
    <h1 id="profile_nickname">@(Model.Detail.DisplayableNickname == 1 ? @Model.Detail?.Nickname : "@" + @Model.Username)</h1>
    <h3 id="profile_username">@@@Model.Username</h3>

       @if(u.Id == Model.Id){
        <div id="profile_friend_button">
            <a href="/Account/Edit">
                <button id="follow-btn" style="width: 150px;">Edit Profile</button>
            </a>
        </div>
        }else if (followed)
        {
            <form data-user="@Model.Id" asp-controller="Account" asp-action="unfollowUser" method="post">
                <input type="hidden" name="targetID" value="@Model.Id" />
                <button type="submit" id="follow-btn">Followed</button>
            </form>
        }
        else{
            <form data-user="@Model.Id" asp-controller="Account" asp-action="FollowUser" method="post">
                <input type="hidden" name="targetID" value="@Model.Id" />
                <button type="submit" onclick="CallAlert('TEST')" id="follow-btn">Follow</button>
            </form> 
        }

    <div id="profile_detail">
        <div style="display: flex;">
            <div id="profile_fcount" onclick="loadUser(@Model.Id, 'GetFollowing')">
                <div id="profile_fcount2">
                    <h2>@Model.Detail!.FollowingCount</h2>
                </div>
                <div id="profile_fcount1">
                    Followings
                </div>
            </div>

            <div id="profile_fcount" onclick="loadUser(@Model.Id, 'GetFollower')">
                <div id="profile_fcount2">
                    <h2>@Model.Detail!.FollowerCount</h2>
                </div>
                <div id="profile_fcount1">
                    Followers
                </div>
            </div>
        </div>

        <div id="profile_jd">
            Join date: @(((DateTime)Model.DateJoin).ToString("yyyy-MM-dd"))
        </div>
    </div>

    <div id="profile_bio">
        <p style="white-space: pre-line;">@Model.Detail.Bio</p>
    </div>
</div>

