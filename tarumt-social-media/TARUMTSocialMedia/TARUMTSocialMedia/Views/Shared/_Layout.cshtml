                                    </span>
                                    <span class="submenu-logout-name">Log out</span>
                                    <span class=submenu-logout-arrow>></span>
                                </div>
                            </a>


                        </div>
                    </div>
                </div>

                <!-- Notification -->
                <a href="/Home/Notification">
                <div id="bell_ico" style="display: inline;">
                    <div class="bellicon">
                        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="45" height="45" viewBox="0 0 24 24">
                            <path d="M17.133 12.632v-1.8a5.406 5.406 0 0 0-4.154-5.262.955.955 0 0 0 .021-.106V3.1a1 1 0 0 0-2 0v2.364a.955.955 0 0 0 .021.106 5.406 5.406 0 0 0-4.154 5.262v1.8C6.867 15.018 5 15.614 5 16.807 5 17.4 5 18 5.538 18h12.924C19 18 19 17.4 19 16.807c0-1.193-1.867-1.789-1.867-4.175ZM8.823 19a3.453 3.453 0 0 0 6.354 0H8.823Z" />
                        </svg>
                    </div>
                    <p class="noti-interact">&nbsp;</p>
                    @if(noti != 0){
                    <div class="noti-count">
                        <p style="position: relative; top:5px">@noti</p>
                    </div>
                    }
                </div>
                </a>

                <!-- Upload content -->
                <a href="/Post/Create">
                <div id="upload_ico">
                    <div class="upload_icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="45" height="45" viewBox="0 0 24 24"><path d="M20.548 3.452a1.542 1.542 0 0 1 0 2.182l-7.636 7.636-3.273 1.091 1.091-3.273 7.636-7.636a1.542 1.542 0 0 1 2.182 0zM4 21h15a1 1 0 0 0 1-1v-8a1 1 0 0 0-2 0v7H5V6h7a1 1 0 0 0 0-2H4a1 1 0 0 0-1 1v15a1 1 0 0 0 1 1z" /></svg>
                    </div>
                    <p class="upload-interact">&nbsp;</p>
                </div>
                </a>

            </div>
    </header>

    <main>
        @RenderBody()
    </main>
 <script src="/js/jquery.min.js"></script>
<script src="/js/jquery.unobtrusive-ajax.min.js"></script>
<script src="/js/jquery.validate.min.js"></script>
<script src="/js/jquery.validate.unobtrusive.min.js"></script>
<script src="/js/app.js"></script>
