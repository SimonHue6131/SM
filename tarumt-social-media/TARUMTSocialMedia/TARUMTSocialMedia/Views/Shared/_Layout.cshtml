                                    </svg>
                                </span>
                                <span class="submenu-name">Blackjack</span>
                                <span class=submenu-arrow>></span>
                            </div>
                        </a>
                        </a>

                        @if (User.IsInRole("1"))
                        {
                            <a href="/Admin/hub">
                                <div class=submenu-admin>
                                    <span class="submenu-admin-icon">
