@inject DB db
@{
    var hideNav = ViewBag.HideNavBar as bool? ?? false;
    var email = User?.Identity?.Name;
    var u = db.Users.FirstOrDefault(x => x.Email == email);

    var noti = 0;
    if (u != null)
    {
        noti = db.Notification.Count(x => x.UserId == u.Id && x.Read == 1);

        // Check Ban
        // var CheckBan = db.BanRecord.Any(b => b.UserId == u.Id && (b.EndDate == null || b.EndDate >= DateTime.Today));
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link rel="shortcut icon" href="~/images/favicon.png">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap">
    <link rel="stylesheet" href="/css/style.css" asp-append-version="true"> 
    @* <link rel="stylesheet" href="/bundle.css"> *@
    @RenderSection("head", false)
    @RenderSection("Styles", false)

</head>
<body>
    <header style="@(hideNav ? "display:none;" : "flex")">
            <div>
            <a href="/"><img src="~/images/logo.png"></a>
            </div>

            <form asp-controller="Home" asp-action="Searching" method="get">
            <div id="search_ico">
                <input type="text" id="searchbox" placeholder="Search something!" name=searchbox value="@ViewBag.searchDraft" style="height: 35px;">
                <input type="submit" id="searchbutton" value="">
            </div>
            </form>

            <div style="width: 100%;">

                <!-- Profile image -->
                <div id="pfp_ico">
                <img src="~/images/profile/@(u?.PhotoURL)" style="width: 50px; height: 50px; ">

                    <!-- Hoverable profile box -->
                    <div id="profilebox">
                        <div style="display: flex;">
                            <span>
                            <img id=pfp src="~/images/profile/@(u?.PhotoURL)" style="width: 90px; height: 90px;">
                            </span>
                            <div style="margin-top: -10px;">
                            <h1 style="margin-left: 10px; width:180px; word-wrap: break-word; white-space: normal;">
                                @(
                                    u?.Username
                                )
                            </h1>
                                <a style="margin-left: 15px;" href="/Account/Edit">
