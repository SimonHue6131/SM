@model List<Comment>
@for (int i = 0; i <= 4; i++)
{
    <br>
}

<style>
    table {
        width: 80%;
        border: 1px solid black;
        margin: auto;
    }

    th {
        font-weight: bold;
        border: 1px solid black;
        background-color: gray;
    }

    td {
        text-align: center;
        border-bottom: 1px solid black;
    }

    .Detail {
        padding: 10px;
        color: white;
        background-color: goldenrod;
        border-radius: 10px;
        text-decoration: none;
    }

    .Ban {
        padding: 10px;
        color: white;
        background-color: darkred;
        border-radius: 10px;
        text-decoration: none;
    }

    .search {
        width: 100px;
        height: 40px;
        border: 1px solid black;
        border-radius: 10px;
        font-size: 20px;
    }

    .Submit {
        padding: 10px;
        color: white;
        background-color: forestgreen;
        border-radius: 10px;
        text-decoration: none;
    }

    input {
        margin-left: 10px;
    }

</style>

<div style="width: 80%; display:flex; margin:auto;">
    <form asp-controller="Admin" asp-action="Commentlist_Search" data-ajax="true" data-ajax-update="#target" method="get">
        <input type="number" class="search" name="id" placeholder="Insert ID">
        <input type="text" class="search" name="username" placeholder="Search Username" style="width: 300px;">
        <input type="number" class="search" name="post" placeholder="Search PostID" style="width: 300px;">
        <input type="text" class="search" name="content" placeholder="Search content" style="width: 300px;">
        <input type="date" name="date" style="width: 200px;">
        <button type="submit" class="Submit"> Search </button>
    </form>
</div>

<div id="target">
    <table style="margin-top: 20px">
        <tr style="border: 1px solid black;">
            <th>ID</th>
            <th>Commenter</th>
            <th>CommenterID</th>
            <th>Post</th>
            <th>Content</th>
            <th>Date Commented</th>
            <th>Action</th>
        </tr>

        @foreach (var u in Model)
        {
            <tr style="height: 50px">
                <td>@u.Id</td>
                <td>@u.User.Username</td>
                <td>@u.UserId</td>
                <td>@u.PostId</td>
                <td style="width:200px;">@u.Content</td>
                <td>@u.DateComment.ToString("yyyy-MM-dd")</td>
                <td>
                    <a href="Detailcomment?commentid=@u.Id" class="Detail">Detail</a>
                    <a href="/Post/Content?PostID=@u.PostId" class="Detail">View</a>

                </td>
            </tr>
        }
    </table>
</div>