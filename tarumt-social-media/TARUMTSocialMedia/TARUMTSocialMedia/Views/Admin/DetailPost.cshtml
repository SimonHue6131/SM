@model Post
@inject DB db
@inject Helper helper

@for (int i = 0; i <= 4; i++)
{
    <br>
}
<style>
    table {
        width: 40%;
        border: 1px solid black;
        margin: auto;
        background-color: white;
    }

    th {
        font-weight: bold;
        border: 1px solid black;
        background-color: gray;
    }

    td {
        text-align: left;
        height: 30px;
        border-bottom: 1px solid black;
    }

    .Detail {
        padding: 10px;
        color: white;
        background-color: goldenrod;
        border-radius: 10px;
        text-decoration: none;
    }

    .Ban {
        padding: 10px;
        color: white;
        background-color: darkred;
        border-radius: 10px;
        text-decoration: none;
    }

    .search {
        width: 100px;
        height: 40px;
        border: 1px solid black;
        border-radius: 10px;
        font-size: 20px;
    }

    .Submit {
        padding: 10px;
        color: white;
        background-color: forestgreen;
        border-radius: 10px;
        text-decoration: none;
    }

    input {
        margin-left: 10px;
    }
</style>

<table>
    <tr>
        <td>Post ID</td>
        <td>@Model.Id</td>
    </tr>

    <tr>
        <td>Original Poster</td>
        <td><a href="/Account/Profile/@@@Model.User.Username/@Model.User.Id">@Model.User.Username (@Model.User.Id)</a></td>
    </tr>


    <tr>
        <td>Info</td>
        <td>@Model.info</td>
    </tr>

    <tr>
        <td>Img1</td>
        <td width="75px">
            @(string.IsNullOrEmpty(Model.img1) ? "Null" : Html.Raw($"<img src='/images/post/{Model.img1}' width='75px' height='75px' />"))
        </td>
    </tr>

    <tr>
        <td>Img2</td>
        <td width="75px">
            @(string.IsNullOrEmpty(Model.img2) ? "Null" : Html.Raw($"<img src='/images/post/{Model.img2}' width='75px' height='75px' />"))
        </td>
    </tr>
    </tr>

    <tr>
        <td>Img3</td>
        <td width="75px">
            @(string.IsNullOrEmpty(Model.img3) ? "Null" : Html.Raw($"<img src='/images/post/{Model.img3}' width='75px' height='75px' />"))
        </td>
    </tr>
    </tr>

    <tr>
        <td>Img4</td>
        <td width="75px">
            @(string.IsNullOrEmpty(Model.img4) ? "Null" : Html.Raw($"<img src='/images/post/{Model.img4}' width='75px' height='75px' />"))
        </td>
    </tr>
    </tr>

   

    <tr>
        <td style="width:50%">Date post</td>
        <td>@Model.DatePost.ToString("yyyy-MM-dd")</td>
    </tr>

    <tr>
        <td>Like</td>
        <td>@Model.LikeCount</td>
    </tr>

    <tr>
        <td>Comment</td>
        <td>@Model.CommentCount</td>
    </tr>

    <tr style="height: 40px">
        <td>Action</td>
        <td>
            <a href="/Post/Content?PostID=@Model.Id" class="Detail">View</a>

       
        </td>
    </tr>

</table>